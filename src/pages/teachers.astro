---
import Button from '../components/Button.astro'
import Card from '../components/Card.astro'
import LinkIcon from '../icons/Link.astro'
import Section from '../components/Section.astro'
import TeachersPhoto from '../components/Teachers/TeachersPhoto.astro'
import Layout from '../layouts/Layout.astro'
---

<Layout title='Docentes' description='Docentes'>
  <header class='custom-container pt-40 pb-20'>
    <h1 class='text-center font-bold text-3xl md:text-4xl'>Docentes</h1>
  </header>
  <main>
    <div class='pb-20 custom-container'>
      <img
        src='https://firebasestorage.googleapis.com/v0/b/ees56-826e3.appspot.com/o/mural.webp?alt=media&token=aba4aa4b-2a19-4292-8f4d-27e5a6e5f407'
        class='w-full max-w-[800px] mx-auto mb-10 border border-[var(--accent-color)]'
        alt='Mural'
      />
    </div>
    <Section title='Normativa docente' centerTitle centerMdTitle class='pb-20'>
      <div class='flex flex-col gap-5 md:flex-row'>
        <Card
          title='Normativa docente'
          description='Presioná el boton para ver la normativa docente completa'
          link='https://normas.gba.gob.ar/documentos/BodONdhz.html'
        >
          <Button class='h-max flex items-center gap-3'>
            Abrir <LinkIcon class='w-5' />
          </Button>
        </Card>
        <Card
          title='Estatuto Docente'
          description='Ley 10579 disponible haciendo click en el boton de abajo'
          link='https://drive.google.com/file/d/1D-1Vc0jecqnkNEXXcUIU2oT0ZnxI_ncK/view?usp=sharing'
        >
          <Button class='h-max flex items-center gap-3'>
            Abrir <LinkIcon class='w-5' />
          </Button>
        </Card>
        <Card
          title='Ley de Educación Nacional'
          description='Ley 26206 disponible haciendo click en el boton de abajo'
          link='https://drive.google.com/file/d/1p6zZytrrWJv5DnGqA386YSc_thNPNMZb/view?usp=sharing'
        >
          <Button class='h-max flex items-center gap-3'>
            Abrir <LinkIcon class='w-5' />
          </Button>
        </Card>
      </div>
    </Section>
    <Section
      title='Equipo de conducción'
      centerTitle
      centerMdTitle
      class='pb-20'
    >
      <div class='flex gap-5 justify-evenly text-center'>
        <TeachersPhoto
          name='Andrea Campos'
          img='https://firebasestorage.googleapis.com/v0/b/ees56-826e3.appspot.com/o/andrea-campos.webp?alt=media&token=3760f49e-3950-4a05-ac6c-ac60a03266a7'
