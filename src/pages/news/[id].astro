---
import Layout from '../../layouts/Layout.astro'
import news from '../../data/news.json'
import DetailPage from '../../components/DetailPage.astro'
const { id } = Astro.params
const novelty = news.news.find(novelty => novelty.id === Number(id))
const { title, description, media, mediaType, date, link } = novelty
---

<Layout title='Novedades' description='Novedades'>
  <DetailPage
    title={title}
    description={description}
    media={media}
    date={date}
    mediaType={mediaType}
    link={link}
  />
</Layout>
