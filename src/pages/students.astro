---
import Section from '../components/Section.astro'
import StudyMaterial from '../components/Students/StudyMaterial.astro'
import Future from '../components/Students/Future.astro'
import Layout from '../layouts/Layout.astro'
import ImportantFiles from '../components/Students/ImportantFiles.astro'
import Card from '../components/Card.astro'
---

<Layout title='ESOEF N56 - Estudiantes' description='ESOEF N56 - Estudiantes'>
  <header class='custom-container pt-40 pb-20'>
    <h1 class='text-center font-bold text-3xl md:text-4xl'>Estudiantes</h1>
  </header>
  <main>
    <Section
      class='pb-20'
      title='Archivos importantes'
      centerTitle
      centerMdTitle
    >
      <ImportantFiles />
    </Section>
    <Section
      class='pb-20'
      title='Material de estudio'
      centerTitle
      centerMdTitle
    >
      <StudyMaterial />
    </Section>
    <Section class='pb-20' title='Videoteca' centerTitle centerMdTitle>
      <div class='flex flex-col gap-5'>
        <img src='videoteca.webp' alt='Videoteca' />
        <Card
          title='Videoteca'
          description='Estamos armando una videoteca práctica con material chequeado y en español. El control y el pendrive están en Dirección. (Se aceptan aportes y sugerencias)'
          link='https://drive.google.com/uc?id=1M85JGz0vs1H0FnxkmOL4JHzdgh6F1Rqy&export=download'
        />
      </div>
    </Section>
    <Section class='pb-20' title='Tu futuro' centerTitle centerMdTitle>
      <p class='mb-14 leading-8 text-pretty text-center'>
        Universidades de cercanía. Encontrá toda la información necesaria sobre
        tus próximos estudios
      </p>
      <Future />
    </Section>
  </main>
</Layout>
