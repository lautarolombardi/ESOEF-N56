---
import Section from '../components/Section.astro'
import StudyMaterial from '../components/Students/StudyMaterial.astro'
import ClockIcon from '../icons/Clock.astro'
import FileIcon from '../icons/File.astro'
import Future from '../components/Students/Future.astro'
import Layout from '../layouts/Layout.astro'
---

<Layout title='ESOEF N56 - Estudiantes' description='ESOEF N56 - Estudiantes'>
  <header class='custom-container pt-40 pb-20'>
    <h1 class='text-center font-bold text-3xl'>Estudiantes</h1>
  </header>
  <main>
    <Section class='pb-20'>
      <div
        class='flex flex-col items-center gap-5 md:flex-row md:justify-center md:gap-10'
      >
        <div
          class='h-[200px] w-full max-w-[300px] relative cursor-pointer overflow-hidden schedules'
        >
          <img
            class='h-full object-cover object-center'
            src='horarios.png'
            alt='Horarios'
          />
          <div
            class='absolute bg-[#2689f2c3] text-[var(--white)] text-2xl h-full w-full top-0 left-0 z-20 flex items-center justify-center font-bold transition-all duration-500 btn-hover lg:translate-x-full'
          >
            <a
              class='flex items-center gap-3 transition-all duration-300 hover:underline'
              href='https://docs.google.com/document/d/1Aa1Q-naK7upt5KhW1AGH2RwhNHxC1eA9/edit?usp=sharing&ouid=111141329733704389804&rtpof=true&sd=true'
              target='_blank'><ClockIcon class='w-7' />Horarios</a
            >
          </div>
        </div>
        <div
          class='relative h-[200px] w-full max-w-[300px] cursor-pointer overflow-hidden booklets'
        >
          <img
            class='h-full object-cover object-center'
            src='cuadernillos.png'
            alt='Cuadernillos'
          />
          <div
            class='absolute bg-[#2689f2c3] text-[var(--white)] text-2xl h-full w-full top-0 left-0 z-20 flex items-center justify-center font-bold transition-all duration-500 btn-hover lg:translate-x-full'
          >
            <a
              class='flex items-center gap-3 transition-all duration-300 hover:underline'
              target='_blank'
              href='https://drive.google.com/drive/u/2/folders/1qsJQcVAyW_Uk_1wA9T2gXs6oRsf_VRyN'
              ><FileIcon class='w-7' />Cuadernillos</a
            >
          </div>
        </div>
      </div>
    </Section>
    <Section
      class='pb-20'
      title='Material de estudio'
      centerTitle
      centerMdTitle
    >
      <StudyMaterial />
    </Section>
    <Section class='pb-20' title='Tu futuro' centerTitle centerMdTitle>
      <Future />
    </Section>
  </main>
</Layout>

<style>
  .schedules:hover .btn-hover {
    transform: translateX(0);
  }

  .booklets:hover .btn-hover {
    transform: translateX(0);
  }
</style>
