---
import DetailPage from "@/components/common/DetailPage.astro";
import mediaProductions from "@/data/media-productions.json";
import Layout from "@/layouts/Layout.astro";
const { id } = Astro.params;
const mediaProduction = mediaProductions.mediaProductions.find(
  (k) => k.id === Number(id)
);
const { title, description, media, mediaType, date, link } = mediaProduction;
---

<Layout title="Producción" description="Producción">
  <DetailPage
    cardType="media-productions"
    title={title}
    description={description}
    media={media}
    date={date}
    mediaType={mediaType}
    link={link}
  />
</Layout>
