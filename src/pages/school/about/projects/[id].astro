---
import Layout from '../../../../layouts/Layout.astro'
import projects from '../../../../data/projects.json'
import DetailPage from '../../../../components/DetailPage.astro'
const { id } = Astro.params
const project = projects.projects.find(p => p.id === Number(id))
const { title, description, media, mediaType, date, link } = project
---

<Layout title='Salidas' description='Salidas'>
  <DetailPage
    title={title}
    description={description}
    media={media}
    date={date}
    mediaType={mediaType}
    link={link}
  />
</Layout>
