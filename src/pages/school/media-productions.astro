          allowfullscreen></iframe>
      </div>
    </Section>
    <Section centerMdTitle centerTitle title='Noticiero' class='pb-20'>
      <div
        class='grid gap-5 grid-cols-1 md:grid-cols-2 lg:grid-cols-3 place-content-center'
      >
        <iframe
          class='h-[300px] w-full'
          src='https://www.youtube.com/embed/YKk3-yuvuzw?si=cX-__mNIcAcPxJ0A'
          title='YouTube video player'
          allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
          allowfullscreen></iframe>
