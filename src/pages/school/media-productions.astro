          class='h-[300px] w-full'
          src='https://www.youtube.com/embed/F6l34aaXE5E?si=ZxmavCidRja9yqAK'
          title='YouTube video player'
          allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
          allowfullscreen></iframe>
      </div>
    </Section>
    <Section centerMdTitle centerTitle title='Otras producciones' class='pb-20'>
      <div
        class='custom-container pb-20 flex flex-col items-center gap-5 lg:flex-row'
      >
        {
          Array.from(mediaProductions.mediaProductions).map(
            ({ title, description, media, mediaType, date, id }) => (
              <ImageCard
                cardType='media-productions'
                id={id}
                title={title}
                description={description}
                media={media[0]}
                mediaType={mediaType}
                button='Leer más'
                date={date}
              />
            )
          )
        }
        <iframe
          class='h-[500px] w-full max-w-[700px]'
          src='https://www.youtube.com/embed/EX316IpH8Ls?si=gw-Ai89rkcw07JZo'
          title='YouTube video player'
          allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
          allowfullscreen></iframe>
      </div>
    </Section>
  </main>
</Layout>
