---
import ImageCard from '../../components/ImageCard.astro'
import Section from '../../components/Section.astro'
import Layout from '../../layouts/Layout.astro'
import mediaProductions from '../../data/media-productions.json'
---

<Layout title='Producción' description='Producción'>
  <header class='custom-container pt-40 pb-20'>
    <h1 class='text-center font-bold text-3xl md:text-4xl'>Producción</h1>
  </header>
  <main>
    <Section
      title='Producción audiovisual'
      centerTitle
      centerMdTitle
      class='pb-20'
    >
      <div
        class='grid gap-5 grid-cols-1 md:grid-cols-2 lg:grid-cols-3 place-content-center'
      >
        <iframe
          class='h-[300px] w-full'
          src='https://www.youtube.com/embed/koHN_InIHfk?si=aA2kIn8MCaMuszGa'
          title='YouTube video player'
          allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
          allowfullscreen
        >
        </iframe>
        <iframe
          class='h-[300px] w-full'
          src='https://www.youtube.com/embed/gtTJ5a3kwR0?si=nHu2R9Hos3bsBxdi'
          title='YouTube video player'
          allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
          allowfullscreen
        >
        </iframe>
        <iframe
          class='h-[300px] w-full'
