---
import Button from "@/components/common/Button.astro";
import ImageCard from "@/components/common/ImageCard.astro";
import news from "@/data/news.json";
import Angle from "@/icons/Angle.astro";
---

<div
  class="mb-12 grid gap-5 grid-cols-1 md:grid-cols-2 lg:grid-cols-3 place-content-center"
>
  {
    Array.from(news.news)
      .slice(0, 3)
      .map(({ title, description, media, mediaType, date, id }) => (
        <ImageCard
          cardType="news"
          id={id}
          title={title}
          description={description}
          media={media[0]}
          mediaType={mediaType}
          button="Leer más"
          date={date}
        />
      ))
  }
</div>
<a href="/news"
  ><Button class="h-max flex items-center gap-3">
    Ver todas las novedades <Angle class="w-3 -rotate-90" />
  </Button></a
>
