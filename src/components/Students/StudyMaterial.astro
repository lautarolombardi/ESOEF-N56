---
import Card from "@/components/common/Card.astro";
import studyMaterial from "@/data/students/study-material.json";
---

<div
  class="grid grid-cols-1 place-items-center gap-5 md:grid-cols-[repeat(auto-fill,minmax(300px,1fr))]"
>
  {
    studyMaterial.studyMaterial.map(({ title, description, link }) => (
      <Card title={title} description={description} link={link} />
    ))
  }
</div>
