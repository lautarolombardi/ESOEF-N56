---
import Button from './Button.astro'
import LinkIcon from '../icons/Link.astro'

interface Props {
  title: string
  description: string
  media: string
  mediaType: string
  button: string
  date: string
}

const { title, description, media, mediaType, button, date } = Astro.props
---

<div
  class='max-w-sm bg-[var(--primary-color)] shadow border border-[var(--accent-color)]'
>
  <div class='w-full h-[300px]'>
    {
      mediaType === 'image' ? (
        <img class='w-full h-full object-cover' src={media} />
      ) : (
        <iframe
          src={media}
          class='h-full w-full'
          title='YouTube video player'
          allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
          allowfullscreen
        />
      )
    }
  </div>
  <div class='p-5 flex flex-col gap-4'>
    <h5 class='text-2xl font-bold tracking-tight'>
      {title}
    </h5>
    <p class='leading-7 truncate'>
      {description}
    </p>
    <a href='#'>
      <Button class='flex h-max items-center gap-2'>
        {button}
        <LinkIcon class='w-5' />
      </Button>
    </a>
  </div>
</div>
